function bindGenerateQrForm(): void {
  const form = document.querySelector<HTMLFormElement>('#generateQrForm')
  const button = document.querySelector<HTMLButtonElement>('#generateQrButton')

  form?.addEventListener('submit', async (event) => {
    event.preventDefault()

    if (!selectedListing) {
      showMessage('Select listing first.', 'error')
      return
    }

    if (isGeneratingQr) {
      return
    }

    isGeneratingQr = true

    if (button) {
      button.disabled = true
      button.textContent = 'Generating QR...'
    }

    const formData = new FormData(form)
    const pickupId = numberOrNull(formData.get('pickup_id'))

    const body = {
      waste_listing_id: selectedListing.id,
      pickup_id: pickupId,
      qr_type: String(formData.get('qr_type') || (pickupId ? 'pickup_tracking' : 'waste_tracking')),
      notes: String(formData.get('notes') || ''),
    }

    showMessage('Generating real QR tag...', 'info')

    try {
      const response = await api.post<unknown>('/qr-tags', body)
      const tag = unwrapItem<QrTag>(response)
      showMessage('QR tag generated successfully.', 'success')
      await renderQrTagPanel(tag)
      await loadQrTags()
      await loadQrListings()
    } catch (error: unknown) {
      showMessage(getErrorMessage(error, 'Failed to generate QR tag.'), 'error')
    } finally {
      isGeneratingQr = false

      if (button) {
        button.disabled = false
        button.textContent = 'Generate Real QR Tag'
      }
    }
  })
}


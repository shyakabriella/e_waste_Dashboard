function bindScanQrForm(tagId: number): void {
  const form = document.querySelector<HTMLFormElement>('#scanQrForm')

  form?.addEventListener('submit', async (event) => {
    event.preventDefault()

    const formData = new FormData(form)

    const body = {
      scan_purpose: String(formData.get('scan_purpose') || 'verification'),
      status: String(formData.get('status') || 'scanned'),
      scan_latitude: numberOrNull(formData.get('scan_latitude')),
      scan_longitude: numberOrNull(formData.get('scan_longitude')),
    }

    showMessage('Saving QR scan...', 'info')

    try {
      const response = await api.post<unknown>(`/qr-tags/${tagId}/scan`, body)
      const tag = unwrapItem<QrTag>(response)
      showMessage('QR tag scanned successfully.', 'success')
      await renderQrTagPanel(tag)
      await loadQrTags()
      await loadQrListings()
    } catch (error: unknown) {
      showMessage(getErrorMessage(error, 'Failed to scan QR tag.'), 'error')
    }
  })
}

async function updateQrStatus(id: number, status: string): Promise<void> {
  showMessage(`Updating QR tag to ${status}...`, 'info')

  try {
    const response = await api.put<unknown>(`/qr-tags/${id}`, { status })
    const tag = unwrapItem<QrTag>(response)
    showMessage('QR tag updated successfully.', 'success')
    await renderQrTagPanel(tag)
    await loadQrTags()
  } catch (error: unknown) {
    showMessage(getErrorMessage(error, 'Failed to update QR tag.'), 'error')
  }
}

function fillCurrentGps(): void {
  if (!navigator.geolocation) {
    showMessage('GPS is not supported by this browser.', 'error')
    return
  }

  showMessage('Getting current GPS location...', 'info')

  navigator.geolocation.getCurrentPosition(
    (position) => {
      const lat = document.querySelector<HTMLInputElement>('#scanLatitudeInput')
      const lng = document.querySelector<HTMLInputElement>('#scanLongitudeInput')

      if (lat) {
        lat.value = String(position.coords.latitude)
      }

      if (lng) {
        lng.value = String(position.coords.longitude)
      }

      showMessage('GPS filled successfully.', 'success')
    },
    () => {
      showMessage('Could not get GPS location. Allow location permission and try again.', 'error')
    },
    {
      enableHighAccuracy: true,
      timeout: 15000,
      maximumAge: 0,
    },
  )
}

function buildQrPayload(tag: QrTag, pickup?: Pickup | null): string {
  const listing = tag.wasteListing || tag.waste_listing
  const linkedPickup = pickup || tag.pickup || findPickupForListing(tag.waste_listing_id || listing?.id || 0)

  return JSON.stringify({
    type: 'e_waste_pickup_qr_tag',
    qr_code: tag.qr_code,
    qr_tag_id: tag.id,
    waste_listing_id: tag.waste_listing_id || listing?.id,
    pickup_id: tag.pickup_id || linkedPickup?.id || null,
    pickup_code: linkedPickup?.pickup_code || null,
    driver_id: linkedPickup?.driver_id || null,
    driver_name: linkedPickup?.driver?.name || null,
    institution_id: linkedPickup?.institution_id || listing?.institution_id || null,
    institution_name: linkedPickup?.institution?.institution_name || listing?.institution?.institution_name || listing?.institution?.name || null,
    listing_title: listing?.title || null,
    status: tag.status,
  })
}

async function generateQrImage(payload: string): Promise<string> {
  return QRCode.toDataURL(payload, {
    width: 320,
    margin: 2,
    errorCorrectionLevel: 'M',
  })
}

function printQrTag(): void {
  const printable = document.querySelector<HTMLDivElement>('#printableQrTag')

  if (!printable) {
    return
  }

  const printWindow = window.open('', '_blank', 'width=900,height=700')

  if (!printWindow) {
    window.print()
    return
  }

  printWindow.document.write(`
    <!doctype html>
    <html>
      <head>
        <title>E-Waste QR Tag</title>
        <style>
          body {
            font-family: Arial, sans-serif;
            padding: 24px;
          }

          .tag {
            max-width: 520px;
            margin: 0 auto;
          }

          img {
            max-width: 260px;
          }
        </style>
      </head>
      <body>
        <div class="tag">
          ${printable.innerHTML}
        </div>

        <script>
          window.onload = function () {
            window.print()
          }
        </script>
      </body>
    </html>
  `)

  printWindow.document.close()
}

